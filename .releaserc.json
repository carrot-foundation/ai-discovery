{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/npm", { "tarballDir": "dist-tarball" }],
    [
      "@semantic-release/github",
      {
        "labels": false,
        "assets": [
          {
            "path": "dist-tarball/*.tgz",
            "label": "npm package tarball"
          }
        ]
      }
    ]
  ]
}
