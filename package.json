{
  "name": "@carrot-foundation/ai-discovery",
  "version": "0.0.0-development",
  "description": "AI discovery primitives for the Carrot Network: JSON-LD, llms.txt, robots, and a Markdown mirror.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./jsonld": {
      "import": {
        "types": "./dist/jsonld/index.d.ts",
        "default": "./dist/jsonld/index.js"
      },
      "require": {
        "types": "./dist/jsonld/index.d.cts",
        "default": "./dist/jsonld/index.cjs"
      }
    },
    "./robots": {
      "import": {
        "types": "./dist/robots/index.d.ts",
        "default": "./dist/robots/index.js"
      },
      "require": {
        "types": "./dist/robots/index.d.cts",
        "default": "./dist/robots/index.cjs"
      }
    },
    "./llms-txt": {
      "import": {
        "types": "./dist/llms-txt/index.d.ts",
        "default": "./dist/llms-txt/index.js"
      },
      "require": {
        "types": "./dist/llms-txt/index.d.cts",
        "default": "./dist/llms-txt/index.cjs"
      }
    },
    "./md-mirror": {
      "import": {
        "types": "./dist/md-mirror/index.d.ts",
        "default": "./dist/md-mirror/index.js"
      },
      "require": {
        "types": "./dist/md-mirror/index.d.cts",
        "default": "./dist/md-mirror/index.cjs"
      }
    },
    "./mcp-server": {
      "import": {
        "types": "./dist/mcp-server/index.d.ts",
        "default": "./dist/mcp-server/index.js"
      },
      "require": {
        "types": "./dist/mcp-server/index.d.cts",
        "default": "./dist/mcp-server/index.cjs"
      }
    },
    "./orama": {
      "import": {
        "types": "./dist/orama/index.d.ts",
        "default": "./dist/orama/index.js"
      },
      "require": {
        "types": "./dist/orama/index.d.cts",
        "default": "./dist/orama/index.cjs"
      }
    },
    "./index-now": {
      "import": {
        "types": "./dist/index-now/index.d.ts",
        "default": "./dist/index-now/index.js"
      },
      "require": {
        "types": "./dist/index-now/index.d.cts",
        "default": "./dist/index-now/index.cjs"
      }
    },
    "./glossary": {
      "import": {
        "types": "./dist/glossary/index.d.ts",
        "default": "./dist/glossary/index.js"
      },
      "require": {
        "types": "./dist/glossary/index.d.cts",
        "default": "./dist/glossary/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "carrot",
    "ai",
    "llm",
    "schema-org",
    "jsonld",
    "llms-txt",
    "robots",
    "markdown"
  ],
  "author": "Carrot Foundation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carrot-foundation/ai-discovery.git"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "check": "run-s format:check lint type-check spell-check test build check-types-exports pack:dry-run audit:prod",
    "check-types-exports": "npm_config_cache=.cache/npm attw --pack . --profile node16",
    "fix": "run-s lint:fix format",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --cache --cache-location .cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location .cache/eslint/",
    "pack:dry-run": "pnpm pack --dry-run",
    "prepare": "husky",
    "release": "semantic-release",
    "audit:prod": "pnpm audit --prod --audit-level=critical",
    "spell-check": "cspell lint --dot --no-must-find-files \"**/*.{ts,js,cjs,mjs,md,json,yml,yaml}\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orama/orama": "^3.1.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@eslint/js": "10.0.1",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/node": "25.6.0",
    "cspell": "10.0.0",
    "eslint": "10.3.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jiti": "2.7.0",
    "lint-staged": "17.0.2",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
